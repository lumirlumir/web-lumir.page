{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.tsx",
    "types/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.js",
    "src/**/*.test.mjs",
    "src/**/*.test.cjs",
    "src/**/*.test.jsx",
    "src/**/*.test.ts",
    "src/**/*.test.mts",
    "src/**/*.test.cts",
    "src/**/*.test.tsx",
    "**/fixtures/**"
  ],
  "compilerOptions": {
    /* Modules */
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"] // Map the '@' alias to the 'src' directory.
    },
    "resolveJsonModule": true,
    "rootDir": "./src",
    "types": ["node", "react", "react-dom", "./types/global.d.ts"],

    /* Emit */
    "noEmit": true,

    /* JavaScript Support */
    "allowJs": false, // TODO: Enable this later.
    "checkJs": false, // TODO: Enable this later.

    /* Editor Support */
    "plugins": [
      {
        "name": "next"
      }
    ],

    /* Language and Environment */
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],

    /* Interop Constraints */
    "esModuleInterop": true,

    /* Projects */
    "incremental": true,

    /* Completeness */
    "skipLibCheck": true
  }
}
