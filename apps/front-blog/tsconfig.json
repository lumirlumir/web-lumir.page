{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.tsx",
    "types/*.d.ts"
  ],
  "exclude": [
    "src/**/*.test.js",
    "src/**/*.test.mjs",
    "src/**/*.test.cjs",
    "src/**/*.test.jsx",
    "src/**/*.test.ts",
    "src/**/*.test.mts",
    "src/**/*.test.cts",
    "src/**/*.test.tsx",
    "**/fixtures/**"
  ],
  "compilerOptions": {
    /* Modules */
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"] // Map the '@' alias to the 'src' directory.
    },
    "rootDir": "./src",
    "types": ["node", "react", "react-dom", "./types/globals.d.ts"],

    /* Emit */
    "noEmit": true,

    /* JavaScript Support */
    "allowJs": false, // TODO: Enable this later.
    "checkJs": false, // TODO: Enable this later.

    /* Language and Environment */
    "jsx": "react-jsx",

    /* Completeness */
    "skipLibCheck": true
  }
}
