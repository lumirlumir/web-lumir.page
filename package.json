{
  "private": true,
  "name": "web-lumir.page",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^20.19.6"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "vitest run --coverage",
    "test:a:b": "npm run test -w apps/blog",
    "test:pkg:rk": "npm run test -w packages/react-kit",
    "test:pkg:rhp": "npm run test -w packages/rehype-plugins",
    "test:pkg:rmp": "npm run test -w packages/remark-plugins",
    "test:pkg:u": "npm run test -w packages/utils",
    "dev": "npm-run-all -c -l -p dev:pkg:* dev:a:b",
    "dev:a:b": "npm run dev -w apps/blog",
    "dev:pkg:rk": "npm run dev -w packages/react-kit",
    "dev:pkg:rhp": "npm run dev -w packages/rehype-plugins",
    "dev:pkg:rmp": "npm run dev -w packages/remark-plugins",
    "dev:pkg:u": "npm run dev -w packages/utils",
    "build:a:b": "npm-run-all -c -l -p build:pkg:* && npm run build -w apps/blog",
    "build:pkg": "npm-run-all -c -l -p build:pkg:*",
    "build:pkg:rk": "npm run build -w packages/react-kit",
    "build:pkg:rhp": "npm run build -w packages/rehype-plugins",
    "build:pkg:rmp": "npm run build -w packages/remark-plugins",
    "build:pkg:u": "npm run build -w packages/utils",
    "start:a:b": "npm run start -w apps/blog",
    "fix": "npm-run-all -c -l -p fix:*",
    "fix:eslint": "npx eslint --fix",
    "fix:stylelint": "npx stylelint --fix **/*.css",
    "fix:prettier": "npx prettier . --write --ignore-unknown",
    "fix:markdownlint": "npx markdownlint **/*.md --fix",
    "fix:clangformat": "find . -name '*.h' -o -name '*.c' -o -name '*.cpp' -print0 | xargs -0 npx clang-format -i",
    "lint": "npm-run-all -c -l -p lint:*",
    "lint:eslint": "npx eslint",
    "lint:stylelint": "npx stylelint **/*.css",
    "lint:prettier": "npx prettier . --check --ignore-unknown",
    "lint:editorconfig": "npx editorconfig-checker -config .editorconfig-checker.json",
    "lint:markdownlint": "npx markdownlint **/*.md",
    "lint:clangformat": "find . -name '*.h' -o -name '*.c' -o -name '*.cpp' -print0 | xargs -0 npx clang-format -n -Werror"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.2",
    "clang-format-git": "^3.0.1",
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-bananass": "^0.6.1",
    "eslint-markdown": "^0.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
