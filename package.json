{
  "private": true,
  "name": "web-lumir.page",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^20.19.6"
  },
  "workspaces": [
    ".",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "npm-run-all -c -l -p dev:pkg:* dev:ws",
    "dev:ws": "next dev",
    "dev:pkg:rk": "npm run dev -w packages/react-kit",
    "dev:pkg:u": "npm run dev -w packages/utils",
    "build": "npm-run-all -c -l -p build:pkg:* && next build",
    "build:pkg:rk": "npm run build -w packages/react-kit",
    "build:pkg:u": "npm run build -w packages/utils",
    "start": "next start",
    "fix": "npm-run-all -c -l -p fix:*",
    "fix:eslint": "npx eslint --fix",
    "fix:stylelint": "npx stylelint --fix **/*.{css,scss}",
    "fix:prettier": "npx prettier . --write --ignore-unknown",
    "fix:markdownlint": "npx markdownlint **/*.md --fix --disable MD060",
    "fix:clangformat": "find . -name '*.h' -o -name '*.c' -o -name '*.cpp' -print0 | xargs -0 npx clang-format -i",
    "lint": "npm-run-all -c -l -p lint:*",
    "lint:eslint": "npx eslint",
    "lint:stylelint": "npx stylelint **/*.{css,scss}",
    "lint:prettier": "npx prettier . --check --ignore-unknown",
    "lint:editorconfig": "npx editorconfig-checker -config .editorconfig-checker.json",
    "lint:markdownlint": "npx markdownlint **/*.md --disable MD060",
    "lint:clangformat": "find . -name '*.h' -o -name '*.c' -o -name '*.cpp' -print0 | xargs -0 npx clang-format -n -Werror",
    "count-docs": "ls -R src/posts/docs | grep .md | wc -l"
  },
  "dependencies": {
    "@docsearch/css": "^3.9.0",
    "@docsearch/react": "^3.9.0",
    "@giscus/react": "^3.1.0",
    "@lumir/utils": "^0.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.14",
    "@next/third-parties": "^15.5.14",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "html-react-parser": "^5.2.17",
    "katex": "^0.16.40",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clang-format-git": "^2.0.7",
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-bananass": "^0.6.0",
    "eslint-markdown": "^0.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^16.26.1",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "^5.9.3"
  }
}
