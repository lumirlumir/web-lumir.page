{
  "private": true,
  "name": "@lumir/remark-plugins",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./build/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:types && npm run test:unit",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "remark": "^15.0.1",
    "vitest": "^4.1.1"
  }
}
