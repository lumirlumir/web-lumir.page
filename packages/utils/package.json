{
  "private": true,
  "name": "@lumir/utils",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./build/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:types && npm run test:unit",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
