{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.js",
    "src/**/*.test.mjs",
    "src/**/*.test.cjs",
    "src/**/*.test.jsx",
    "src/**/*.test.ts",
    "src/**/*.test.mts",
    "src/**/*.test.cts",
    "src/**/*.test.tsx",
    "**/fixtures/**"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "types": [],

    /* Emit */
    "declaration": true,
    "outDir": "build"
  }
}
